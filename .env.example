# AI 账号资产管理系统 - 配置示例
# 复制为 .env 并修改（启动脚本里已带默认值，可不建 .env）

# 登录密码（Web 界面用）
AAM_ADMIN_PASSWORD=admin123

# 数据加密主密码（用于加密邮箱密码、GPT 密码等敏感字段）
# 一旦设置后不能更改，否则旧密文无法解密！
AAM_MASTER_PASSWORD=change-this-master-key

# Session Cookie 签名密钥（任意随机字符串）
AAM_SESSION_SECRET=any-random-string-works-here

# 数据库文件路径（默认在项目 data/ 下）
# AAM_DB_PATH=./data/accounts.db
