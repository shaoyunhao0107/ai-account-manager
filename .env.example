# AI 账号资产管理系统 - 配置示例
# 复制为 .env 并修改

# 登录密码（Web 界面用）
AAM_ADMIN_PASSWORD=admin123

# 数据加密主密码（用于加密邮箱密码、GPT 密码等敏感字段）
# 一旦设置后不能更改，否则旧密文无法解密！
AAM_MASTER_PASSWORD=please-change-this-key

# Session Cookie 签名密钥（任意随机字符串）
AAM_SESSION_SECRET=local-dev-secret-xyz

# ========== 数据库配置 ==========

# 方式 1：PostgreSQL（推荐，生产环境用）
AAM_DB_URL=postgresql://aam_user:aam_pass_2026@localhost:5432/ai_account_manager

# 方式 2：SQLite（默认，开发用）
# 清空 AAM_DB_URL 即回退到 SQLite
# AAM_DB_URL=
# AAM_DB_PATH=./data/accounts.db
